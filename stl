#include <iostream>
#include <vector>
#include <list>
#include <set>
#include <algorithm>
using namespace std;
int main()
{
/*---------------- VECTOR ----------------*/
vector<int> v = {40, 10, 30, 20, 10};
sort(v.begin(), v.end());
cout << "Sorted Vector: ";
for (int x : v)
cout << x << " "<<endl;
auto it1 = find(v.begin(), v.end(), 30);
if (it1 != v.end())
cout << "30 found in vector\n";
cout << "Count of 10 in vector: " << count(v.begin(), v.end(), 10) << endl;
/*---------------- LIST ----------------*/
list<int> l = {5, 2, 8, 2, 1};
l.sort();
cout << "\nSorted List: ";
for (int x : l)
cout << x << " "; cout << endl;
auto it2 = find(l.begin(), l.end(), 8);
if (it2 != l.end())
cout << "8 found in list\n";
cout << "Count of 2 in list: " << count(l.begin(), l.end(), 2) << endl;
/*---------------- SET ----------------*/
set<int> s = {7, 3, 9, 1, 3}; // duplicates ignored
cout << "\nSet Elements (Already Sorted): ";
for (int x : s)
cout << x << " "; cout << endl;
auto it3 = find(s.begin(), s.end(), 7);
if (it3 != s.end())
cout << "7 found in set\n";
cout << "Count of 3 in set: "
<< count(s.begin(), s.end(), 3) << endl;
return 0;
}
