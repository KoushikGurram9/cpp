#include <iostream>
#include <list>
#include <string>
using namespace std;
int main()
{
// Creating a list of strings
list<string> names;
// Inserting elements
names.push_back("Varsha");
names.push_back("Harsha");
names.push_front("Saharsha");
names.push_back("SriHarsha");
cout << "List after insertion:\n";
// Traversing using iterator
list<string>::iterator it;
for (it = names.begin(); it != names.end(); ++it)
{
cout << *it << " ";
}
// Deleting an element
names.remove("Saharsha");
cout << "\n\nList after deletion (removing 'Saharsha'):\n";
// Traversing again using iterator
for (it = names.begin(); it != names.end(); ++it)
{
cout << *it << " ";
}
cout << endl;
return 0;
}
