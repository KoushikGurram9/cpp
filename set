#include <iostream>
#include <set>
using namespace std;
int main()
{
// Creating a set of integers
set<int> numbers;
// Inserting elements (including duplicates)
numbers.insert(50);
numbers.insert(20);
numbers.insert(40);
numbers.insert(10);
numbers.insert(30);
numbers.insert(20); // duplicate value
// Displaying elements in sorted order
cout << "Unique integers of Set in sorted order:\n";
set<int>::iterator it;
for (it = numbers.begin(); it != numbers.end(); ++it) {
cout << *it << " ";
}
cout << endl;
return 0;
}
